# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit the relayer key
.env*
!.env.example

# vercel
.vercel

# local tooling
.claude/

# stray local image drops (reveal-campaign WIP etc.) — keep out of the public repo
/images/

# typescript
*.tsbuildinfo
next-env.d.ts
